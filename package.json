{
  "name": "evermore",
  "description": "A simple terminal workspace for developers.",
  "version": "1.2.0",
  "author": "ytakahashi",
  "dependencies": {
    "@electron-toolkit/preload": "3.0.2",
    "@electron-toolkit/utils": "4.0.0",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-unicode11": "0.9.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/xterm": "6.0.0",
    "clsx": "2.1.1",
    "electron-store": "11.0.2",
    "lucide-react": "1.24.0",
    "node-pty": "1.1.0",
    "ssh-config": "5.2.0",
    "tailwind-merge": "3.6.0",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "3.1.0",
    "@electron-toolkit/tsconfig": "2.0.0",
    "@tailwindcss/vite": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "eslint": "10.7.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "homepage": "https://github.com/ytakahashi/evermore",
  "license": "MIT",
  "main": "./out/main/index.js",
  "packageManager": "pnpm@11.0.9",
  "repository": {
    "type": "git",
    "url": "https://github.com/ytakahashi/evermore"
  },
  "scripts": {
    "build": "pnpm run typecheck && electron-vite build",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:mac:dev": "electron-vite build && electron-builder --mac --dir -c electron-builder.dev.yml",
    "build:unpack": "pnpm run build && electron-builder --dir",
    "notarize:dmg": "xcrun notarytool submit dist/Evermore-$npm_package_version.dmg --key $APPLE_API_KEY --key-id $APPLE_API_KEY_ID --issuer $APPLE_API_ISSUER --wait && xcrun stapler staple dist/Evermore-$npm_package_version.dmg",
    "release:mac": "pnpm run build:mac && pnpm run notarize:dmg",
    "dev": "electron-vite dev",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "postinstall": "electron-builder install-app-deps",
    "start": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false"
  },
  "type": "module"
}
